# INSTRUCCIONES:
# 1. Copie este archivo como ".env" (sin el .example)
#    cp .env.example .env
# 2. Complete con sus credenciales reales de PostgreSQL
# 3. NUNCA suba el archivo .env al repositorio
# ============================================================

# --- Conexión PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=olist_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# --- Kaggle API (para descarga automática del dataset) ---
KAGGLE_USERNAME=tu_usuario_kaggle
KAGGLE_KEY=tu_api_key_kaggle

# --- Rutas de datos ---
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
